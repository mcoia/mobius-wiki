# =============================================================================
# MOBIUS Wiki - Multi-Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.multi-env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Shared PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD

# -----------------------------------------------------------------------------
# Session Secrets (MUST be different for each environment)
# Generate with: openssl rand -base64 48
# -----------------------------------------------------------------------------
SESSION_SECRET_STAGING=CHANGE_ME_64_CHAR_RANDOM_STRING_FOR_STAGING
SESSION_SECRET_PROD=CHANGE_ME_64_CHAR_RANDOM_STRING_FOR_PRODUCTION

# -----------------------------------------------------------------------------
# Email (Optional - for password resets, notifications)
# -----------------------------------------------------------------------------
MAIL_TRANSPORT=smtp
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mobiusconsortium.org
SMTP_FROM_NAME=MOBIUS Wiki
