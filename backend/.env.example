# PostgreSQL Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=mobius_wiki
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mobius_wiki

# Session Configuration
SESSION_SECRET=your_secure_random_string_min_32_chars_change_this_in_production

# Application Configuration
NODE_ENV=development
PORT=10000
FRONTEND_URL=http://localhost:4200

# SMTP Configuration (Postfix Relay)
# Leave SMTP_HOST empty to disable email functionality
SMTP_HOST=your-postfix-relay.example.com
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER and SMTP_PASSWORD are optional for relay servers
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@mobiusconsortium.org
SMTP_FROM_NAME=MOBIUS Wiki
