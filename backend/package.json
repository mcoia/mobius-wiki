{
  "name": "backend",
  "version": "1.0.0",
  "description": "Complete PostgreSQL database schema for the MOBIUS Wiki platform with 14 tables and migration tracking. All tables are organized within the `wiki` schema for better namespace isolation.",
  "main": "index.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:create": "bash scripts/create-db.sh",
    "migrate": "bash scripts/run-migrations.sh",
    "migrate:status": "bash scripts/migration-status.sh",
    "migrate:rollback": "bash scripts/rollback-migration.sh",
    "db:seed": "node scripts/seed-setup.js",
    "db:seed:test": "node scripts/seed-test.js",
    "db:seed:all": "npm run db:seed && npm run db:seed:test",
    "db:setup": "npm run db:create && npm run migrate && npm run db:seed",
    "db:setup:dev": "npm run db:create && npm run migrate && npm run db:seed:all",
    "test:connection": "node scripts/test-connection.js",
    "sql": "node scripts/sql.js",
    "db:snapshot": "node scripts/db-snapshot.js",
    "import:mediawiki": "node scripts/import-mediawiki.js",
    "import:mediawiki-files": "node scripts/import-mediawiki-files.js",
    "import:download-images": "node scripts/download-mediawiki-images.js",
    "db:reset:clean": "node scripts/reset-and-import.js",
    "db:reset:clean:dry-run": "node scripts/reset-and-import.js --dry-run",
    "db:package": "bash scripts/package-production.sh",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/throttler": "^6.5.0",
    "asciidoctor": "^3.0.4",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.2.3",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "puppeteer": "^24.37.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "simple-git": "^3.30.0",
    "turndown": "^7.2.2",
    "wtf_wikipedia": "^10.4.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/turndown": "^5.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
