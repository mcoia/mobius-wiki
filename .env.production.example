# =============================================================================
# MOBIUS Wiki - Production Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
# In Docker Compose, the database host is 'db' (the service name)
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=mobius_wiki
DATABASE_USER=postgres
# IMPORTANT: Change this to a strong password!
DATABASE_PASSWORD=change-me-to-strong-password

# -----------------------------------------------------------------------------
# Session Security
# -----------------------------------------------------------------------------
# CRITICAL: Generate a secure random string (64+ characters)
# Generate with: openssl rand -hex 32
# Example: SESSION_SECRET=a1b2c3d4e5f6...
SESSION_SECRET=GENERATE_64_CHAR_RANDOM_STRING_HERE

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=10000

# IMPORTANT: Set this to your actual domain
FRONTEND_URL=https://wiki.mobius.org

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------
# Options: 'smtp' or 'sendmail'
MAIL_TRANSPORT=smtp

# SMTP Settings (when MAIL_TRANSPORT=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# From address (used by both transports)
SMTP_FROM_EMAIL=noreply@mobius.org
SMTP_FROM_NAME=MOBIUS Wiki

# Sendmail Settings (when MAIL_TRANSPORT=sendmail)
# SENDMAIL_PATH=/usr/sbin/sendmail

# -----------------------------------------------------------------------------
# Security Notes
# -----------------------------------------------------------------------------
# 1. DATABASE_PASSWORD: Use a strong, unique password (16+ characters)
# 2. SESSION_SECRET: Must be random and at least 64 characters
#    Generate with: openssl rand -hex 32
# 3. SMTP_PASSWORD: Consider using app-specific passwords where available
# 4. Never commit this file to version control
# 5. Restrict file permissions: chmod 600 .env
