# MOBIUS Wiki Production Environment
# Generated by Ansible - Do not edit manually
# {{ ansible_date_time.iso8601 }}

# =============================================================================
# Node Environment
# =============================================================================
NODE_ENV={{ node_env | default('production') }}

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_HOST={{ database_host | default('db') }}
DATABASE_PORT={{ database_port | default(5432) }}
DATABASE_NAME={{ database_name | default('mobius_wiki') }}
DATABASE_USER={{ database_user | default('postgres') }}
DATABASE_PASSWORD={{ database_password }}
DATABASE_URL=postgresql://{{ database_user | default('postgres') }}:{{ database_password }}@{{ database_host | default('db') }}:{{ database_port | default(5432) }}/{{ database_name | default('mobius_wiki') }}

# =============================================================================
# Session Configuration
# =============================================================================
SESSION_SECRET={{ session_secret }}
SESSION_MAX_AGE={{ session_max_age | default(86400000) }}

# =============================================================================
# Application URLs
# =============================================================================
FRONTEND_URL=https://{{ domain_name }}
BACKEND_URL=https://{{ domain_name }}/api

# =============================================================================
# Server Configuration
# =============================================================================
PORT=10000
LOG_LEVEL={{ log_level | default('info') }}

# =============================================================================
# File Upload Configuration
# =============================================================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE={{ max_upload_size | default(52428800) }}

# =============================================================================
# Email Configuration
# =============================================================================
{% if smtp_enabled | default(false) %}
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port | default(587) }}
SMTP_USER={{ smtp_user }}
SMTP_PASSWORD={{ smtp_password }}
SMTP_FROM_EMAIL={{ smtp_from_email | default('noreply@mobius.org') }}
SMTP_FROM_NAME={{ smtp_from_name | default('MOBIUS Wiki') }}
SMTP_SECURE=false
{% else %}
# SMTP not configured - password reset emails disabled
{% endif %}

# =============================================================================
# Security
# =============================================================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
