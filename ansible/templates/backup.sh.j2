#!/bin/bash
# MOBIUS Wiki Backup Script
# Generated by Ansible - Do not edit manually
#
# This script creates daily backups of:
#   - PostgreSQL database
#   - Uploaded files
#
# Backups are retained for 7 days.

set -euo pipefail

# Configuration
BACKUP_DIR="{{ backup_dir }}"
APP_DIR="{{ app_dir }}"
DATE=$(date +%Y%m%d_%H%M%S)
RETENTION_DAYS=7

# Logging
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1"
}

log "Starting MOBIUS Wiki backup..."

# Create backup directory if it doesn't exist
mkdir -p "$BACKUP_DIR"

# Database backup
log "Backing up database..."
docker compose -f "$APP_DIR/docker-compose.yml" exec -T db \
    pg_dump -U {{ database_user | default('postgres') }} {{ database_name | default('mobius_wiki') }} \
    | gzip > "$BACKUP_DIR/db_$DATE.sql.gz"

if [ $? -eq 0 ]; then
    log "Database backup complete: db_$DATE.sql.gz"
else
    log "ERROR: Database backup failed!"
    exit 1
fi

# Uploads backup
log "Backing up uploads..."
docker compose -f "$APP_DIR/docker-compose.yml" exec -T backend \
    tar -czf - /app/uploads 2>/dev/null \
    > "$BACKUP_DIR/uploads_$DATE.tar.gz"

if [ $? -eq 0 ]; then
    log "Uploads backup complete: uploads_$DATE.tar.gz"
else
    log "WARNING: Uploads backup may have failed or directory is empty"
fi

# Cleanup old backups
log "Cleaning up backups older than $RETENTION_DAYS days..."
find "$BACKUP_DIR" -name "*.gz" -mtime +$RETENTION_DAYS -delete

# Show backup sizes
log "Current backups:"
ls -lh "$BACKUP_DIR"/*.gz 2>/dev/null || log "No backup files found"

# Calculate total backup size
TOTAL_SIZE=$(du -sh "$BACKUP_DIR" | cut -f1)
log "Total backup size: $TOTAL_SIZE"

log "Backup complete!"
